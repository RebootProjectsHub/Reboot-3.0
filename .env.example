# Contact form email delivery (Resend — https://resend.com)
# Create an API key in the Resend dashboard and paste it here in .env.local
RESEND_API_KEY=

# Optional overrides (sensible defaults are used if unset):
# Where contact-form submissions are delivered (your Google Workspace inbox)
# CONTACT_TO=hallo@reboot.no
# The verified sender address (must be on a domain verified in Resend)
# CONTACT_FROM=Reboot nettside <skjema@reboot.no>
